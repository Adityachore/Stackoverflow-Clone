# MongoDB Connection String
# Replace with your actual MongoDB connection string
# For local MongoDB: mongodb://localhost:27017/stackoverflow-clone
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/stackoverflow-clone
MONGODB_URI=mongodb://localhost:27017/stackoverflow-clone

# CORS Allowed Origins (comma-separated for multiple origins)
# For development: http://localhost:3000
# For production: https://stackoverflow-clone-e7dp.vercel.app
CORS_ORIGIN=https://stackoverflow-clone-e7dp.vercel.app

# Server Port
PORT=5000

# JWT Secret Key
# Generate a secure random string for production
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# JWT Expiration Time
JWT_EXPIRE=7d

# Node Environment
NODE_ENV=development

# ─── Razorpay Payment Gateway ───────────────────────────────────────────────
# Get these from https://dashboard.razorpay.com/app/keys
# Use rzp_test_* keys for testing, rzp_live_* for production
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# ─── Email / Nodemailer (for subscription invoices, OTP, etc.) ───────────────
# Use Gmail App Password (not your real password)
# Enable 2FA on Gmail then create an App Password at:
# https://myaccount.google.com/apppasswords
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password_here

# ─── Google OAuth ────────────────────────────────────────────────────────────
# From https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback
